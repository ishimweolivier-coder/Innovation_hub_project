# Copy to .env and fill in values (do not commit .env)
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# Gmail app password (create at https://myaccount.google.com/apppasswords)
MAIL_USERNAME=kwizerasteven2000@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_FROM=Innovation Hub <innovationhub@gmail.com>
FRONTEND_URL=http://localhost:5173

# Brevo (Sendinblue) transactional email API key (alternative to Gmail SMTP)
BREVO_API_KEY=your-brevo-api-key

# Inactive user detection — users without login in N days are marked INACTIVE (auto-reactivated on next login)
INACTIVITY_DAYS=90
INACTIVITY_CRON=0 0 3 * * ?

# Admin bootstrap credentials — only used on first startup or when admin doesn't exist
ADMIN_EMAIL=olivierishimwe006@gmail.com
ADMIN_PASSWORD=@olivier
ADMIN_NAME=olivier Ishimwe
